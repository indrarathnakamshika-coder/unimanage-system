@model IEnumerable<UniManage.Models.Assignment>
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Assignments";
    var role = Context.Session.GetString("UserRole");
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-0">Assignments</h3>
            <small class="text-muted">Manage and review assignments</small>
        </div>

        <div class="d-flex gap-2">
            <input id="assignmentSearch" type="search" class="form-control form-control-sm" placeholder="Search assignments..." style="min-width:260px;" />
            @if (role == "Lecturer")
            {
                <a asp-controller="Assignment" asp-action="Create" class="btn btn-sm btn-primary"><i class="bi bi-plus-lg me-1"></i> New Assignment</a>
            }
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table id="assignmentsTable" class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th class="d-none d-md-table-cell">Description</th>
                            <th>Deadline</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">No assignments found.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr data-title="@item.Title" data-desc="@item.Description" data-deadline="@item.Deadline.ToString("yyyy-MM-dd")">
                                    <td class="fw-semibold">@item.Title</td>
                                    <td class="d-none d-md-table-cell text-muted">@item.Description</td>
                                    <td>@item.Deadline.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td class="text-end">
                                        <div class="btn-group" role="group">
                                            <a asp-action="Details" asp-route-id="@item.AssignmentId" class="btn btn-sm btn-outline-secondary" title="View"><i class="bi bi-eye"></i></a>
                                            @if (role == "Student")
                                            {
                                                var submitted = (ViewBag.SubmittedAssignments as System.Collections.Generic.HashSet<int>) ?? new System.Collections.Generic.HashSet<int>();
                                                if (submitted.Contains(item.AssignmentId))
                                                {
                                                    <span class="badge bg-success me-2">Submitted</span>
                                                    <a asp-action="Submit" asp-route-id="@item.AssignmentId" class="btn btn-sm btn-outline-primary" title="Update submission">Update</a>
                                                }
                                                else
                                                {
                                                    <a asp-action="Submit" asp-route-id="@item.AssignmentId" class="btn btn-sm btn-primary" title="Submit"><i class="bi bi-upload"></i> Submit</a>
                                                }
                                            }
                                            @if (role == "Lecturer")
                                            {
                                                <a asp-action="GradeList" asp-controller="Assignment" class="btn btn-sm btn-outline-primary" title="Grade"><i class="bi bi-journal-check"></i></a>
                                                <a asp-action="Edit" asp-controller="Assignment" asp-route-id="@item.AssignmentId" class="btn btn-sm btn-outline-warning" title="Edit"><i class="bi bi-pencil-square"></i></a>
                                                <form asp-action="Delete" asp-controller="Assignment" method="post" class="d-inline" onsubmit="return confirm('Delete this assignment?');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@item.AssignmentId" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    (function(){
        const search = document.getElementById('assignmentSearch');
        const table = document.getElementById('assignmentsTable');
        function filter(){
            const q = (search.value||'').toLowerCase().trim();
            Array.from(table.tBodies[0].rows).forEach(row => {
                const title = (row.dataset.title||'').toLowerCase();
                const desc = (row.dataset.desc||'').toLowerCase();
                const match = !q || title.includes(q) || desc.includes(q);
                row.style.display = match ? '' : 'none';
            });
        }
        search && search.addEventListener('input', filter);
    })();
</script>
