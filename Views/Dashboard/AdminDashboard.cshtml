<h2>Admin Dashboard</h2>
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="mb-4">
    <small class="text-muted">Overview & key metrics</small>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-primary text-white rounded p-3">
                    <i class="bi bi-people-fill fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Total Users</div>
                    <div id="totalUsers" class="fs-5 fw-bold">--</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-success text-white rounded p-3">
                    <i class="bi bi-book-half fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Courses</div>
                    <div id="totalCourses" class="fs-5 fw-bold">--</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-warning text-dark rounded p-3">
                    <i class="bi bi-journal-check fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Enrollments</div>
                    <div id="totalEnrollments" class="fs-5 fw-bold">--</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-info text-white rounded p-3">
                    <i class="bi bi-chat-dots-fill fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Messages</div>
                    <div id="totalMessages" class="fs-5 fw-bold">--</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <strong>User Roles</strong>
                <small class="text-muted">Distribution</small>
            </div>
            <div class="card-body">
                <canvas id="roleChart" style="max-height:360px;"></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <div>
                    <strong>Enrollments</strong>
                    <div class="text-muted small">Last 6 months</div>
                </div>
                <div class="text-muted small">Trend</div>
            </div>
            <div class="card-body">
                <canvas id="enrollmentsChart" style="max-height:360px;"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <strong>Top Courses</strong>
                <small class="text-muted">by enrollments</small>
            </div>
            <div class="card-body">
                <canvas id="coursesChart" style="max-height:320px;"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        (function () {
            function palette(count) {
                const base = ['#0d6efd', '#6610f2', '#198754', '#dc3545', '#fd7e14', '#20c997', '#6f42c1', '#0dcaf0', '#ffc107', '#d63384'];
                return base.slice(0, Math.max(1, count));
            }

            // Load summary totals for cards
            fetch('@Url.Action("SummaryTotals", "Dashboard")')
                .then(r => r.json())
                .then(t => {
                    document.getElementById('totalUsers').textContent = t.users ?? t.Users ?? '--';
                    document.getElementById('totalCourses').textContent = t.courses ?? t.Courses ?? '--';
                    document.getElementById('totalEnrollments').textContent = t.enrollments ?? t.Enrollments ?? '--';
                    document.getElementById('totalMessages').textContent = t.messages ?? t.Messages ?? '--';
                }).catch(e => console.error(e));

            // Role pie chart
            fetch('@Url.Action("RoleDistribution", "Dashboard")')
                .then(r => r.json())
                .then(data => {
                    const ctx = document.getElementById('roleChart').getContext('2d');
                    new Chart(ctx, {
                        type: 'doughnut',
                        data: {
                            labels: data.labels,
                            datasets: [{ data: data.data, backgroundColor: palette(data.data.length) }]
                        },
                        options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
                    });
                }).catch(console.error);

            // Enrollments line chart
            fetch('@Url.Action("EnrollmentsOverTime", "Dashboard")')
                .then(r => r.json())
                .then(data => {
                    const ctx = document.getElementById('enrollmentsChart').getContext('2d');
                    new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: data.labels,
                            datasets: [{
                                label: 'Enrollments',
                                data: data.data,
                                borderColor: '#0d6efd',
                                backgroundColor: 'rgba(13,110,253,0.08)',
                                tension: 0.35,
                                fill: true,
                                pointRadius: 3
                            }]
                        },
                        options: {
                            responsive: true,
                            scales: { y: { beginAtZero: true, precision: 0 } },
                            plugins: { legend: { display: false } }
                        }
                    });
                }).catch(console.error);

            // Top courses horizontal bar
            fetch('@Url.Action("TopCoursesByEnrollments", "Dashboard")')
                .then(r => r.json())
                .then(data => {
                    const ctx = document.getElementById('coursesChart').getContext('2d');
                    new Chart(ctx, {
                        type: 'bar',
                        data: { labels: data.labels, datasets: [{ label: 'Enrollments', data: data.counts, backgroundColor: palette(data.counts.length) }] },
                        options: {
                            responsive: true,
                            indexAxis: 'y',
                            scales: { x: { beginAtZero: true, precision: 0 } },
                            plugins: { legend: { display: false } }
                        }
                    });
                }).catch(console.error);
        })();
    </script>
}
