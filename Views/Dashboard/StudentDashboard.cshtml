@inherits Microsoft.AspNetCore.Mvc.Razor.RazorPage<UniManage.Models.StudentDashboardViewModel>

@model UniManage.Models.StudentDashboardViewModel

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0">Student Dashboard</h2>
        <small class="text-muted">Overview of courses, upcoming deadlines, and grades</small>
    </div>
    <div class="d-flex gap-2">
    </div>
</div>

<div class="row g-4 mt-3">
    <div class="col-12 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header">Submissions Over Time</div>
            <div class="card-body">
                <canvas id="submissionsOverTimeChart" height="120"></canvas>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header">Graded Submissions by Course</div>
            <div class="card-body">
                <canvas id="gradesByCourseChart" height="120"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-12 col-lg-4">
        <div class="card shadow-sm">
            <div class="card-header">Enrolled Courses</div>
            <div class="card-body">
                @if (Model.EnrolledCourses == null || !Model.EnrolledCourses.Any())
                {
                    <div class="text-muted">You are not enrolled in any courses.</div>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var c in Model.EnrolledCourses)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fw-semibold">@c.CourseCode</div>
                                    <div class="small text-muted">@c.CourseName</div>
                                </div>
                                <a asp-controller="Course" asp-action="Materials" asp-route-courseId="@c.CourseId" class="btn btn-sm btn-outline-secondary">Materials</a>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-8">
        <div class="card shadow-sm mb-3">
            <div class="card-header">Upcoming Assignment Deadlines</div>
            <div class="card-body">
                @if (Model.UpcomingAssignments == null || !Model.UpcomingAssignments.Any())
                {
                    <div class="text-muted">No upcoming assignments.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Title</th>
                                    <th>Course</th>
                                    <th>Deadline</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var a in Model.UpcomingAssignments)
                                {
                                    <tr>
                                        <td class="fw-semibold">@a.Title</td>
                                        <td class="small text-muted">@Model.EnrolledCourses.FirstOrDefault(c => c.CourseId == a.CourseId)?.CourseName ?? a.CourseId.ToString()</td>
                                        <td>@a.Deadline.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <canvas id="deadlinesChart" height="120" class="mt-3"></canvas>
                }
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header">Grades & Feedback</div>
            <div class="card-body">
                @if (Model.Submissions == null || !Model.Submissions.Any())
                {
                    <div class="text-muted">No submissions yet.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Assignment</th>
                                    <th>Course</th>
                                    <th>Submitted</th>
                                    <th>Grade</th>
                                    <th>Feedback</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in Model.Submissions)
                                {
                                    <tr>
                                        <td class="fw-semibold">@s.AssignmentTitle</td>
                                        <td class="small text-muted">@s.CourseName</td>
                                        <td>@s.SubmissionDate.ToLocalTime().ToString("yyyy-MM-dd")</td>
                                        <td>@(string.IsNullOrEmpty(s.Grade) ? "-" : s.Grade)</td>
                                        <td class="small text-muted">@(string.IsNullOrEmpty(s.Feedback) ? "-" : s.Feedback)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <canvas id="gradesChart" height="120" class="mt-3"></canvas>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        (function(){
            // grades pie chart
            fetch('@Url.Action("StudentGradeStatus","Dashboard")')
                .then(r => r.json())
                .then(data => {
                    var ctx = document.getElementById('gradesChart');
                    if (!ctx) return;
                    new Chart(ctx, {
                        type: 'pie',
                        data: {
                            labels: data.labels,
                            datasets: [{ data: data.data, backgroundColor: ['#198754','#6c757d'] }]
                        }
                    });
                });

            // deadlines bar chart
            fetch('@Url.Action("StudentUpcomingAssignments","Dashboard")')
                .then(r => r.json())
                .then(data => {
                    var ctx = document.getElementById('deadlinesChart');
                    if (!ctx) return;
                    new Chart(ctx, {
                        type: 'bar',
                        data: {
                            labels: data.labels,
                            datasets: [{ label: 'Days left', data: data.data, backgroundColor: '#0d6efd' }]
                        },
                        options: { indexAxis: 'y', scales: { x: { beginAtZero: true } } }
                    });
                });

            // submissions over time (last 6 months)
            fetch('@Url.Action("StudentSubmissionsOverTime","Dashboard")')
                .then(r => r.json())
                .then(data => {
                    var ctx = document.getElementById('submissionsOverTimeChart');
                    if (!ctx) return;
                    new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: data.labels,
                            datasets: [{ label: 'Submissions', data: data.data, borderColor: '#198754', backgroundColor: 'rgba(25,135,84,0.1)', fill: true }]
                        },
                        options: { scales: { y: { beginAtZero: true, precision:0 } } }
                    });
                });

            // graded submissions by course
            fetch('@Url.Action("StudentGradesByCourse","Dashboard")')
                .then(r => r.json())
                .then(data => {
                    var ctx = document.getElementById('gradesByCourseChart');
                    if (!ctx) return;
                    new Chart(ctx, {
                        type: 'bar',
                        data: {
                            labels: data.labels,
                            datasets: [{ label: 'Graded submissions', data: data.data, backgroundColor: '#0d6efd' }]
                        },
                        options: { scales: { y: { beginAtZero: true, precision:0 } } }
                    });
                });
        })();
    </script>
}

