
@{
    ViewData["Title"] = "Home";
}

<!-- HERO -->
<section class="hero-section py-6 min-vh-100 d-flex align-items-center justify-content-center">
    <div class="container text-center">
        <div class="row justify-content-center">
            <div class="col-12 col-lg-8 text-white">
                <h1 class="display-5 fw-bold mb-3">UniManage — Modern university management</h1>
                <p class="lead mb-4 text-white-50">Manage courses, enrollments, assignments and communication in a single polished platform designed for administrators, lecturers and students.</p>

                <div class="d-flex gap-2 flex-wrap justify-content-center">
                    <a asp-controller="Account" asp-action="Register" class="btn btn-secondary btn-lg px-4">Get Started</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FEATURES -->
<section class="features-section py-5">
    <div class="container">
        <div class="text-center mb-4">
            <h3 class="mb-2">Powerful features built for education</h3>
            <p class="text-muted">Everything you need to run courses, manage users and review performance.</p>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-card p-4 h-100">
                    <div class="icon-box mb-3">
                        <i class="bi bi-people-fill fs-3"></i>
                    </div>
                    <h5 class="fw-semibold">User Management</h5>
                    <p class="text-muted small">Add and manage students, lecturers and admins with role-based access.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card p-4 h-100">
                    <div class="icon-box mb-3" style="background:#E6FFFA;color:#0f5132;">
                        <i class="bi bi-journal-check fs-3"></i>
                    </div>
                    <h5 class="fw-semibold">Enrollment & Assignments</h5>
                    <p class="text-muted small">Streamlined enrollment flows and assignment submission tracking.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card p-4 h-100">
                    <div class="icon-box mb-3" style="background:#FFF4E6;color:#7a4d00;">
                        <i class="bi bi-bar-chart-line fs-3"></i>
                    </div>
                    <h5 class="fw-semibold">Reports & Analytics</h5>
                    <p class="text-muted small">Visualize course performance, enrollments and user activity with built-in charts.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA FOOTER -->
<section class="cta-section py-5 bg-primary text-white">
    <div class="container d-md-flex align-items-center justify-content-between">
        <div>
            <h4 class="fw-bold mb-1">Ready to modernize your university?</h4>
            <p class="mb-0 text-white-50 small">Start with a free account and explore the administration tools.</p>
        </div>
        <div class="mt-3 mt-md-0">
            <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg">Create Account</a>
        </div>
    </div>
</section>

<!-- Page-specific styles -->
<style>
    :root { --primary: #0d6efd; --dark-900: #071A3A; }
    .hero-section { background: linear-gradient(135deg, var(--dark-900), #123a6f); color: #fff; }
    .hero-card { border-radius: 12px; background: rgba(255,255,255,0.05); }
    .features-section { background: #f8fafc; }
    .feature-card { border-radius: 12px; background: #fff; border: 1px solid #eef2f7; transition: transform .28s ease, box-shadow .28s ease; }
    .feature-card:hover { transform: translateY(-6px); box-shadow: 0 10px 30px rgba(16,24,40,0.06); }
    .icon-box { width:72px; height:72px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:28px; background:#e8f0ff; color:var(--primary); margin:0 auto 10px; }
    .cta-section { background: linear-gradient(90deg,#0b5ed7,#0d6efd); }
    .text-white-50 { color: rgba(255,255,255,0.75); }

    /* Responsive tweaks */
    @@media (max-width: 991px) {
        .hero-card { margin-top: 24px; }
    }
</style>

<script>
    // Populate small stats in hero by calling Dashboard summary endpoint
    (function(){
        fetch('@Url.Action("SummaryTotals","Dashboard")')
            .then(r => r.json())
            .then(t => {
                var elUsers = document.getElementById('hpUsers');
                var elCourses = document.getElementById('hpCourses');
                var elEnroll = document.getElementById('hpEnrollments');
                if (elUsers) elUsers.textContent = t.Users ?? t.users ?? '--';
                if (elCourses) elCourses.textContent = t.Courses ?? t.courses ?? '--';
                if (elEnroll) elEnroll.textContent = t.Enrollments ?? t.enrollments ?? '--';
            }).catch(()=>{});
    })();
</script>
