<h2>Reporting and Analytics</h2>

@{
    ViewData["Title"] = "Reports";
}

<div class="container">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h2 class="mb-0">Reports</h2>
            <small class="text-muted">System-wide statistics and exports</small>
        </div>

        <div class="d-flex gap-2 align-items-center">
            <div class="d-flex gap-2 me-3">
                <input type="date" id="filterStart" class="form-control form-control-sm" />
                <input type="date" id="filterEnd" class="form-control form-control-sm" />
                <button id="applyFilters" class="btn btn-sm btn-primary">Apply</button>
                <button id="resetFilters" class="btn btn-sm btn-outline-secondary">Reset</button>
            </div>

            <div class="d-flex gap-2">
                <a href="@Url.Action("DownloadUsersCsv", "Report")" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-download me-1"></i> Users CSV
                </a>
                <a href="@Url.Action("DownloadCoursesCsv", "Report")" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-download me-1"></i> Courses CSV
                </a>
                <a href="@Url.Action("DownloadEnrollmentsCsv", "Report")" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-download me-1"></i> Enrollments CSV
                </a>
                    <button id="loadLecturerWorkload" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-person-lines-fill me-1"></i> Lecturer Workload
                    </button>
                <button id="downloadPdf" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-file-earmark-pdf-fill me-1"></i> Export PDF
                </button>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="bg-primary text-white rounded p-3">
                        <i class="bi bi-people-fill fs-3"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Total Users</div>
                        <div class="fs-4 fw-bold">@ViewBag.TotalUsers</div>
                    </div>
                    <div class="ms-auto">
                        <a href="@Url.Action("DownloadUsersCsv","Report")" class="btn btn-sm btn-outline-secondary"><i class="bi bi-download"></i></a>
                    </div>
                </div>

<div class="container mt-4">
    <div class="card">
        <div class="card-body">
            <h5>Lecturer Workload</h5>
            <div id="lecturerWorkloadContainer">
                <div class="text-muted">Click "Lecturer Workload" to load data.</div>
            </div>
        </div>
    </div>
</div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="bg-success text-white rounded p-3">
                        <i class="bi bi-book-half fs-3"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Total Courses</div>
                        <div class="fs-4 fw-bold">@ViewBag.TotalCourses</div>
                    </div>
                    <div class="ms-auto">
                        <a href="@Url.Action("DownloadCoursesCsv","Report")" class="btn btn-sm btn-outline-secondary"><i class="bi bi-download"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="bg-warning text-dark rounded p-3">
                        <i class="bi bi-journal-check fs-3"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Total Enrollments</div>
                        <div class="fs-4 fw-bold">@ViewBag.TotalEnrollments</div>
                    </div>
                    <div class="ms-auto">
                        <a href="@Url.Action("DownloadEnrollmentsCsv","Report")" class="btn btn-sm btn-outline-secondary"><i class="bi bi-download"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <div class="text-muted small">Total Assignments</div>
                    <div class="fs-4 fw-bold">@ViewBag.TotalAssignments</div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <div class="text-muted small">Total Messages</div>
                    <div class="fs-4 fw-bold">@ViewBag.TotalMessages</div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <div class="text-muted small">Students</div>
                    <div class="fs-4 fw-bold">@ViewBag.TotalStudents</div>
                </div>
            </div>
        </div>

        <div class="col-12 mt-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="mb-3">Analytics</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <canvas id="enrollmentChart" style="max-height:240px;"></canvas>
                        </div>
                        <div class="col-md-6">
                            <canvas id="roleChart" style="max-height:240px;"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>

    <script>
        (function(){
            function palette(count){
                const base = ['#0d6efd','#6610f2','#198754','#dc3545','#fd7e14','#20c997'];
                return base.slice(0, Math.max(1,count));
            }

            // Utility to format a Date to yyyy-MM-dd
            function fmt(d){
                if(!d) return '';
                const dt = new Date(d);
                const m = (dt.getMonth()+1).toString().padStart(2,'0');
                const day = (dt.getDate()).toString().padStart(2,'0');
                return dt.getFullYear()+"-"+m+"-"+day;
            }

            // Chart instances
            let enrollmentChart = null;
            let roleChart = null;

            function loadEnrollmentChart(start, end){
                let url = '@Url.Action("EnrollmentsOverTime","Report")';
                if(start && end){
                    url += `?start=${encodeURIComponent(start)}&end=${encodeURIComponent(end)}`;
                }

                fetch(url).then(r=>r.json()).then(data=>{
                    const ctx = document.getElementById('enrollmentChart').getContext('2d');
                    if(enrollmentChart) enrollmentChart.destroy();
                    enrollmentChart = new Chart(ctx,{
                        type: 'line',
                        data: { labels: data.labels, datasets: [{ label: 'Enrollments', data: data.data, borderColor: '#0d6efd', backgroundColor: 'rgba(13,110,253,0.08)', tension: 0.3, fill: true }] },
                        options: { responsive: true, scales: { y: { beginAtZero: true } } }
                    });

            // Lecturer workload loader
            document.getElementById('loadLecturerWorkload')?.addEventListener('click', function(){
                const container = document.getElementById('lecturerWorkloadContainer');
                container.innerHTML = '<div class="text-muted">Loading...</div>';
                fetch('@Url.Action("LecturerWorkloadData","Report")')
                    .then(r => r.json())
                    .then(data => {
                        if(!data || data.length === 0){
                            container.innerHTML = '<div class="text-muted">No lecturer data available.</div>';
                            return;
                        }

                        let html = [];
                        html.push('<div class="table-responsive">');
                        html.push('<table class="table table-sm table-striped">');
                        html.push('<thead><tr><th>Lecturer</th><th class="text-end">Courses</th><th class="text-end">Materials</th><th class="text-end">Messages</th></tr></thead>');
                        html.push('<tbody>');
                        data.forEach(function(item){
                            html.push('<tr>');
                            html.push('<td>' + (item.fullName || item.FullName || item.Fullname || item.Fullname) + '</td>');
                            html.push('<td class="text-end">' + (item.coursesCount ?? item.CoursesCount ?? 0) + '</td>');
                            html.push('<td class="text-end">' + (item.materialsUploaded ?? item.MaterialsUploaded ?? 0) + '</td>');
                            html.push('<td class="text-end">' + (item.messagesReceived ?? item.MessagesReceived ?? 0) + '</td>');
                            html.push('</tr>');
                        });
                        html.push('</tbody></table></div>');
                        container.innerHTML = html.join('');
                    })
                    .catch(() => {
                        container.innerHTML = '<div class="text-danger">Error loading lecturer workload.</div>';
                    });
            });
                }).catch(()=>{});
            }

            function loadRoleChart(){
                fetch('@Url.Action("RoleDistribution","Dashboard")').then(r=>r.json()).then(data=>{
                    const ctx = document.getElementById('roleChart').getContext('2d');
                    if(roleChart) roleChart.destroy();
                    roleChart = new Chart(ctx,{
                        type: 'doughnut',
                        data: { labels: data.labels, datasets: [{ data: data.data, backgroundColor: palette(data.data.length) }] },
                        options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
                    });
                }).catch(()=>{});
            }

            // Init default charts (last 6 months)
            (function init(){
                // default date range: six months back to now
                const now = new Date();
                const sixMonthsBack = new Date(now.getFullYear(), now.getMonth()-5, 1);
                const startInput = document.getElementById('filterStart');
                const endInput = document.getElementById('filterEnd');
                if(startInput && endInput){
                    startInput.value = fmt(sixMonthsBack);
                    endInput.value = fmt(now);
                }

                loadEnrollmentChart(startInput.value, endInput.value);
                loadRoleChart();
            })();

            // Filter handlers
            document.getElementById('applyFilters')?.addEventListener('click', function(){
                const s = document.getElementById('filterStart').value;
                const e = document.getElementById('filterEnd').value;
                if(!s || !e){
                    alert('Please select both start and end dates');
                    return;
                }
                loadEnrollmentChart(s, e);
            });

            document.getElementById('resetFilters')?.addEventListener('click', function(){
                const now = new Date();
                const sixMonthsBack = new Date(now.getFullYear(), now.getMonth()-5, 1);
                document.getElementById('filterStart').value = fmt(sixMonthsBack);
                document.getElementById('filterEnd').value = fmt(now);
                loadEnrollmentChart(document.getElementById('filterStart').value, document.getElementById('filterEnd').value);
            });

            // PDF export: capture the analytics card and header summary
            document.getElementById('downloadPdf')?.addEventListener('click', async function(){
                const container = document.querySelector('.container');
                if(!container){ alert('Nothing to export'); return; }

                // use html2canvas to capture the container
                const canvas = await html2canvas(container, { scale: 2 });
                const imgData = canvas.toDataURL('image/png');

                const { jsPDF } = window.jspdf;
                const pdf = new jsPDF('p', 'pt', 'a4');
                const pageWidth = pdf.internal.pageSize.getWidth();
                const pageHeight = pdf.internal.pageSize.getHeight();

                // fit image to page width with aspect ratio
                const imgProps = pdf.getImageProperties(imgData);
                const imgWidth = pageWidth - 40; // margins
                const imgHeight = (imgProps.height * imgWidth) / imgProps.width;

                pdf.addImage(imgData, 'PNG', 20, 20, imgWidth, imgHeight);
                pdf.save('reports.pdf');
            });

        })();
    </script>
}
