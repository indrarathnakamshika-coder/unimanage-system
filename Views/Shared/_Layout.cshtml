<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UniManage</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/UniManage.styles.css" asp-append-version="true" />

    <!-- Theme styles are provided in ~/css/site.css (navy / gray / white) -->
</head>

<body>

    @using Microsoft.AspNetCore.Http
    @{
        var role = Context.Session.GetString("UserRole");
    }

    <header>
        <!-- NAVBAR -->
        <nav class="navbar navbar-expand-lg navbar-dark navbar-custom shadow-sm">
            <div class="container-fluid px-4">

                <!-- BRAND -->
                <a class="navbar-brand fw-bold fs-3 d-flex align-items-center gap-2"
                   asp-controller="Home" asp-action="Index">
                    <i class="bi bi-mortarboard-fill"></i>
                    UniManage
                </a>

                <!-- TOGGLER -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- MENU -->
                <div class="collapse navbar-collapse" id="mainNavbar">

                    <ul class="navbar-nav ms-auto gap-2">

                        @if (role == null)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-house-door-fill me-1"></i> Home
                                </a>
                            </li>
                        }

                        @if (role == null)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Register">
                                    <i class="bi bi-person-plus-fill me-1"></i> Register
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i> Login
                                </a>
                            </li>
                        }

                        @if (role == "Student")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Dashboard" asp-action="StudentDashboard">
                                    <i class="bi bi-speedometer2 me-1"></i> Student Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Course" asp-action="Index">
                                    <i class="bi bi-book-fill me-1"></i> Courses
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Enrollment" asp-action="MyEnrollments">
                                    <i class="bi bi-journal-check me-1"></i> My Enrollments
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Assignment" asp-action="Index">
                                    <i class="bi bi-pencil-square me-1"></i> Assignments
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Message" asp-action="Inbox">
                                    <i class="bi bi-chat-dots-fill me-1"></i> Messages
                                </a>
                            </li>
                        }

                        @if (role == "Lecturer")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Dashboard" asp-action="LecturerDashboard">
                                    <i class="bi bi-speedometer2 me-1"></i> Lecturer Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Course" asp-action="Index">
                                    <i class="bi bi-book-fill me-1"></i> Courses
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Assignment" asp-action="Index">
                                    <i class="bi bi-pencil-square me-1"></i> Assignments
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Assignment" asp-action="GradeList">
                                    <i class="bi bi-clipboard-check-fill me-1"></i> Grades
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Message" asp-action="Inbox">
                                    <i class="bi bi-chat-dots-fill me-1"></i> Messages
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Report" asp-action="Index">
                                    <i class="bi bi-bar-chart-fill me-1"></i> Reports
                                </a>
                            </li>
                        }

                        @if (role == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Dashboard" asp-action="AdminDashboard">
                                    <i class="bi bi-speedometer2 me-1"></i> Admin Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Course" asp-action="Index">
                                    <i class="bi bi-gear-fill me-1"></i> Manage Courses
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Report" asp-action="Index">
                                    <i class="bi bi-bar-chart-fill me-1"></i> Reports
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Message" asp-action="AdminInbox">
                                    <i class="bi bi-envelope-fill me-1"></i> Messages
                                </a>
                            </li>
                        }
                        @if (role != null)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right me-1"></i> Logout
                                </a>
                            </li>
                        }

                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- MAIN CONTENT -->
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    <footer class="border-top footer text-muted py-3">
        <div class="container">
            &copy; 2026 - UniManage -
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>